{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "makerblocks/html-tag-base",
	"version": "0.1.0",
	"title": "<base>",
	"category": "makerblocks-html-tags",
	"icon": "tag",
	"description": "The <base> HTML tag defines the base URL for relative URLs on a web page.",
	"attributes": {
		"href": {
			"type": "string",
			"default": ""
		},
		"target": {
			"type": "string",
			"default": "_self"
		}
	},
	"supports": {
		"html": false,
		"multiple": false,
		"reusable": false
	},
	"example": {
		"attributes": {
			"href": "https://www.example.com/",
			"target": "_blank"
		}
	},
	"textdomain": "makerblocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
